# =============================================================================
# ALMa — environment variables
# =============================================================================
# Copy to `.env`, fill in the values you have, and leave the rest blank.
# `.env` is gitignored AND dockerignored — it stays on your machine.
#
#   cp .env.example .env
#   chmod 600 .env
#
# The Settings UI reads these values redacted and can rotate them. Most
# UI-tuned options (Discovery weights, AI provider selection) are stored
# in the SQLite database, not here. See docs/reference/configuration.md
# for the full reference.
# =============================================================================

# --- OpenAlex (primary paper / author source) --------------------------------
# REQUIRED since 2026-02-13: OpenAlex now needs an API key on every request
# (the old email "polite pool" was discontinued). Without a key you get
# 100 free credits/day, then HTTP 409. Grab a free key in ~30s at:
#   https://openalex.org/settings/api
# NOTE: no spaces around `=` — Docker `env_file` keeps spaces in the var
# name, which silently drops the key (→ keyless → 409).
OPENALEX_API_KEY=
# Optional contact email. The OpenAlex polite pool is gone, but a contact
# email still sets a courteous User-Agent and feeds the Crossref polite pool.
OPENALEX_EMAIL=

# --- Semantic Scholar (S2) ---------------------------------------------------
# Strongly recommended (secondary metadata + SPECTER2 vectors + related
# papers). Without a key you share the anonymous worldwide pool (~5000 req
# / 5 min for ALL anonymous clients) and hit 429s constantly, which stalls
# the Discovery graph lane. Free key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# --- Embedding provider (optional) -------------------------------------------
# OpenAI's embedding API is one of the supported embedding providers
# (alongside local SPECTER2 and S2). If you only use S2 / local SPECTER2,
# leave this blank.
OPENAI_API_KEY=

# --- Crossref ---------------------------------------------------------------
# Email for Crossref's polite pool — same idea as OPENALEX_EMAIL.
CROSSREF_MAILTO=

# --- Slack notifier plugin (optional) ----------------------------------------
# Set both to enable digest delivery via Slack.
SLACK_TOKEN=
SLACK_CHANNEL=

# --- API auth (optional) -----------------------------------------------------
# Set a non-empty value to require `X-API-Key: <value>` on every request.
# Leave blank for single-user local mode (default). Required when you
# expose ALMa beyond localhost.
API_KEY=
