# =============================================================================
# ALMa — environment variables
# =============================================================================
# Copy to `.env`, fill in the values you have, and leave the rest blank.
# `.env` is gitignored AND dockerignored — it stays on your machine.
#
#   cp .env.example .env
#   chmod 600 .env
#
# The Settings UI reads these values redacted and can rotate them. Most
# UI-tuned options (Discovery weights, AI provider selection) are stored
# in the SQLite database, not here. See docs/reference/configuration.md
# for the full reference.
# =============================================================================

# --- OpenAlex (paper / author source) ----------------------------------------
# Email for the OpenAlex polite pool. Strongly recommended — without it
# you share the anonymous rate limit with every other anonymous client.
OPENALEX_EMAIL=
# Optional premium API key. Without it, the polite-pool rate limits apply.
OPENALEX_API_KEY=

# --- Semantic Scholar (S2) ---------------------------------------------------
# Optional. Used as a secondary metadata + embedding source. With a key,
# S2's batch and related-paper endpoints have higher quotas.
SEMANTIC_SCHOLAR_API_KEY=

# --- Embedding provider (optional) -------------------------------------------
# OpenAI's embedding API is one of the supported embedding providers
# (alongside local SPECTER2 and S2). If you only use S2 / local SPECTER2,
# leave this blank.
OPENAI_API_KEY=

# --- Crossref ---------------------------------------------------------------
# Email for Crossref's polite pool — same idea as OPENALEX_EMAIL.
CROSSREF_MAILTO=

# --- Slack notifier plugin (optional) ----------------------------------------
# Set both to enable digest delivery via Slack.
SLACK_TOKEN=
SLACK_CHANNEL=

# --- API auth (optional) -----------------------------------------------------
# Set a non-empty value to require `X-API-Key: <value>` on every request.
# Leave blank for single-user local mode (default). Required when you
# expose ALMa beyond localhost.
API_KEY=
