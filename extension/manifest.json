{
  "manifest_version": 3,
  "name": "ALMa Connector",
  "version": "0.14.0",
  "description": "Save the paper open in your browser straight into ALMa — like the Zotero connector, for your personal ALMa library.",
  "browser_specific_settings": {
    "gecko": {
      "id": "alma-connector@costantinoai.github.io",
      "strict_min_version": "115.0"
    }
  },
  "icons": {
    "48": "icons/alma.svg",
    "96": "icons/alma.svg",
    "128": "icons/alma.svg"
  },
  "action": {
    "default_title": "Save this paper to ALMa",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/alma.svg",
      "32": "icons/alma.svg",
      "48": "icons/alma.svg"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["lib/extract.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*",
        "http://localhost:8001/*",
        "http://127.0.0.1:8001/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8001/*",
    "http://127.0.0.1:8001/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"]
}
